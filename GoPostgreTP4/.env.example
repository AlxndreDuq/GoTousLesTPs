PORT=8080
DATABASE_URL=postgres://mira:mira@localhost:5432/mira?sslmode=disable

# Nombre de workers du pool d'enrichissement
ENRICHMENT_WORKERS=4
# Taille du buffer du channel interne de jobs d'enrichissement
ENRICHMENT_QUEUE_SIZE=100
# Timeout appliqué à chaque tâche d'enrichissement
ENRICHMENT_TIMEOUT=10s

# Utilisée par la CLI mira (cmd/mira)
MIRA_API_URL=http://localhost:8080